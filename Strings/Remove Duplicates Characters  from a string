#include<iostream>
#include<string>
using namespace std;

int main(){
    string str = "amman";
    string result = "";

    for(char ch:str){

        bool duplicate = false;

        for(char r : result){
            if(ch == r){
                duplicate = true;
                break;
            }
        }

        if(!duplicate){
            result = result + ch;
        }

    }

    cout<<"Result ="<<result<<endl;
    return 0;
}
