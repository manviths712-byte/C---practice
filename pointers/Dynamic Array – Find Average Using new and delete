#include<iostream>
using namespace std;

int main(){

    int n;
    cout<<"Enter number of elements: ";
    cin>>n;

    int *arr = new int[n];   // dynamic memory allocation

    cout<<"Enter elements:"<<endl;

    for(int i=0;i<n;i++){
        cin>>*(arr+i);       // pointer arithmetic input
    }

    int sum = 0;

    for(int i=0;i<n;i++){
        sum += *(arr+i);     // accessing elements using pointer
    }

    float avg = (float)sum/n;

    cout<<"Sum = "<<sum<<endl;
    cout<<"Average = "<<avg<<endl;

    delete[] arr;   // free memory

    return 0;
}
