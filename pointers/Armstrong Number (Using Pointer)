#include<iostream>
using namespace std;

int main(){
    int num, temp, sum = 0;

    cout << "Enter number: ";
    cin >> num;

    int *ptr = &num;

    temp = *ptr;

    while(temp != 0){
        int digit = temp % 10;
        sum = sum + digit * digit * digit;
        temp = temp / 10;
    }

    if(sum == *ptr)
        cout << "Armstrong Number";
    else
        cout << "Not Armstrong";

    return 0;
}
