#include<iostream>
using namespace std;

int main(){
    int arr[5] = {1,2,3,4,5};

    int *start = arr;        // pointer to first element
    int *end = arr + 4;      // pointer to last element

    while(start < end){
        int temp = *start;
        *start = *end;
        *end = temp;

        start++;   // move forward
        end--;     // move backward
    }

    cout<<"Reversed array: ";

    for(int i=0;i<5;i++){
        cout<<arr[i]<<" ";
    }

    return 0;
}
