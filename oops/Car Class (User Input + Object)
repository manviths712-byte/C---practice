#include<iostream>
using namespace std;

class Car{
public:
    string brand;
    int speed;

    void input(){
        cout<<"Enter car brand: ";
        cin>>brand;

        cout<<"Enter speed: ";
        cin>>speed;
    }

    void display(){
        cout<<"Car Brand: "<<brand<<endl;
        cout<<"Speed: "<<speed<<" km/h"<<endl;
    }
};

int main(){

    Car c1;

    c1.input();
    c1.display();

    return 0;
}
